{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "bpsr-module-optimizer",
  "version": "0.4.1",
  "identifier": "com.bpsr.moduleoptimizer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "bpsr-module-optimizer",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "Rererr",
    "license": "GPL-3.0-only",
    "copyright": "Copyright (c) 2026 Rererr. GPL-3.0-only.",
    "resources": ["./WinDivert.dll", "./WinDivert64.sys"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installerHooks": "./windivert-hooks.nsh"
      }
    }
  }
}
